[Unit]
Description=超采集算系统 系统守护进程
After=multi-user.target network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/super_calc
ExecStart=/usr/bin/python3 /home/pi/super_calc/system_daemon.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target